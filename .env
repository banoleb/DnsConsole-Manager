# dnsdist Web API - Environment Variables Configuration
# Copy this file to .env and customize the values as needed

# Web API Server Settings
# Port for the Web API server (default: 8080)
WEBAPI_PORT=8085

TIMEOUT_AGENT=2
# Host to bind Web API server to (default: 0.0.0.0)
WEBAPI_HOST=0.0.0.0

# Web Console Settings
# Port for the Web Console (default: 5000)
CONSOLE_PORT=5000

# Host to bind Web Console to (default: 0.0.0.0)
CONSOLE_HOST=0.0.0.0

# DNSDist Console Connection Settings
# DNSDist console host (default: 127.0.0.1)
DNSDIST_CONSOLE_HOST=127.0.0.1

# DNSDist console port (default: 5199)
DNSDIST_CONSOLE_PORT=5199

# Change the token for the syncer.sh script (for the system user) before running.
DNSDIST_SYNCER_TOKEN = 32c7002bdfae61eceefa36b10bd1e950520527c1a60292d1daa4f86326de3324

# DNSDist console encryption key (setKey() is configured in dnsdist)
DNSDIST_KEY=your-secret-key

# Authentication Settings
# Web API authentication token (clients must provide in X-Agent-Token header)
WEBAPI_TOKEN=your-secure-token

# Database Settings
# Database URL - supports SQLite, PostgreSQL, etc.
# SQLite example (default):
DATABASE_URL=sqlite:///dnsdist_webapi.db
# PostgreSQL example:
#DATABASE_URL=postgresql://psql:psqlmaster@127.0.0.1:5432/psql

# Logging Settings
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Log format (default: '%(asctime)s - %(name)s - %(levelname)s - %(message)s')
# LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Debug mode (default: false)
# Set to 'true', '1', or 'yes' to enable debug mode
DEBUG=false

# Victoria Metrics Settings
# Enable/disable Victoria Metrics integration (default: false)
# Set to 'true', '1', or 'yes' to enable Victoria Metrics integration
VICTORIA_METRICS_ENABLED=false

# Victoria Metrics host (default: localhost)
VICTORIA_METRICS_HOST=localhost

# Victoria Metrics port (default: 8428)
VICTORIA_METRICS_PORT=8428

# Victoria Metrics URL path (default: /api/v1/import/prometheus)
VICTORIA_METRICS_URL=/api/v1/import/prometheus

# Basic auth
AUTH_ENABLED=false
# -------------------------------------------------------------------------
# OpenID Connect (OIDC / OAuth 2.0) SSO settings
# -------------------------------------------------------------------------
# Set OIDC_ENABLED=true to activate SSO via any OpenID Connect provider
# (e.g. Keycloak, Azure AD, Google, Okta, Authentik …).
OIDC_ENABLED=false
# Base URL of the OIDC provider.
# The discovery document is fetched from <OIDC_PROVIDER_URL>/.well-known/openid-configuration
# Examples:
#   Keycloak : https://sso.example.com/realms/myrealm
#   Google   : https://accounts.google.com
#   Azure AD : https://login.microsoftonline.com/<tenant-id>/v2.0
OIDC_PROVIDER_URL=https://sso.example.com/realms/myrealm

# OAuth 2.0 client credentials (register your app in the OIDC provider)
OIDC_CLIENT_ID=credentials
OIDC_CLIENT_SECRET=credentials

# Full redirect URI that the provider will call after authentication.
# Must match the redirect URI registered in the OIDC provider exactly.
# Example: http://dnsconsole.example.com/auth/callback
OIDC_REDIRECT_URI=http://dnsconsole.example.com/auth/callback
# Space-separated list of OIDC scopes to request.
# 'openid' is required; add 'groups' or provider-specific scopes as needed.
OIDC_SCOPES=openid email profile

# Optional: name of the claim in the ID token / userinfo response that
# contains the list of groups the user belongs to.
# Common values: 'groups' (Keycloak, Authentik), 'roles', 'group_membership'
OIDC_GROUPS_CLAIM=groups

# Optional: if non-empty, only users that belong to this group (as reported
# by OIDC_GROUPS_CLAIM) are allowed to log in.
# Example: OIDC_REQUIRED_GROUP=network
OIDC_REQUIRED_GROUP=dnsadmin