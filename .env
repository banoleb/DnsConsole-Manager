# dnsdist Web API - Environment Variables Configuration
# Copy this file to .env and customize the values as needed

# Web API Server Settings
# Port for the Web API server (default: 8080)
WEBAPI_PORT=8080

# Host to bind Web API server to (default: 0.0.0.0)
WEBAPI_HOST=0.0.0.0

# Web Console Settings
# Port for the Web Console (default: 5000)
CONSOLE_PORT=5000

# Host to bind Web Console to (default: 0.0.0.0)
CONSOLE_HOST=0.0.0.0

# DNSDist Console Connection Settings
# DNSDist console host (default: 127.0.0.1)
DNSDIST_CONSOLE_HOST=127.0.0.1

# DNSDist console port (default: 5199)
DNSDIST_CONSOLE_PORT=5199

# DNSDist console encryption key (optional, only if setKey() is configured in dnsdist)
# DNSDIST_KEY=your-secret-key

# Authentication Settings
# Web API authentication token (optional, clients must provide in X-Agent-Token header)
# WEBAPI_TOKEN=your-secure-token

# Database Settings
# Database URL - supports SQLite, PostgreSQL, etc.
# SQLite example (default):
DATABASE_URL=sqlite:///dnsdist_webapi.db
# PostgreSQL example:
#DATABASE_URL=postgresql://psql:psqlmaster@127.0.0.1:5432/psql

# Logging Settings
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Log format (default: '%(asctime)s - %(name)s - %(levelname)s - %(message)s')
# LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Debug mode (default: false)
# Set to 'true', '1', or 'yes' to enable debug mode
DEBUG=false

# Victoria Metrics Settings
# Enable/disable Victoria Metrics integration (default: false)
# Set to 'true', '1', or 'yes' to enable Victoria Metrics integration
VICTORIA_METRICS_ENABLED=false

# Victoria Metrics host (default: localhost)
VICTORIA_METRICS_HOST=localhost

# Victoria Metrics port (default: 8428)
VICTORIA_METRICS_PORT=8428

# Victoria Metrics URL path (default: /api/v1/import/prometheus)
VICTORIA_METRICS_URL=/api/v1/import/prometheus
